# Copy this file to .env and fill in values. NEVER commit .env.
# Pick ONE data provider in Phase 2 (see docs/SPEC.md open decisions).

# Alpaca (free market data with an account; paper account also serves Phase 4)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Polygon.io (paid; cleaner / longer 1-min history)
POLYGON_API_KEY=

# Telegram alerts (optional): message @BotFather -> /newbot for the token, then
# run scripts/telegram_setup.py to discover your chat id. Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
